# ShiftCrew Owner — environment
# These point at the shared ShiftMatch Supabase project. ShiftCrew only ever
# reads ShiftMatch's public tables (for login/role checks) and reads/writes its
# OWN isolated schema (shiftcrew_owner). It never writes to ShiftMatch data.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
